# Flask Configuration
FLASK_CONFIG=development
SECRET_KEY=your-secret-key-change-in-production

# Use SQLite for development (set to false to use PostgreSQL)
USE_SQLITE=false

# PostgreSQL Database Configuration (used when USE_SQLITE=false)
DATABASE_URL=postgresql://postgres:password@localhost:5432/company_reports

# Or use individual database parameters
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=company_reports
