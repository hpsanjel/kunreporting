# Flask Configuration
# For development: FLASK_CONFIG=development
# For production: FLASK_CONFIG=production
FLASK_CONFIG=development
SECRET_KEY=your-secret-key-change-in-production

USE_SQLITE=false

DATABASE_URL=postgresql://postgres:password@localhost:5432/company_reports

DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=company_reports
